# RENAME THIS FILE FROM "TEMPLATE.env" to ".env"
 
# Use your own key here
QRX_SYNC_KEY=xxx
 
# Namespaces to include
QRX_PUBLIC_NAMESPACES=main,wiki,cache
 
# Private namespaces — served only to requests with the correct Authorization header
# Not included in the static GitHub Pages build
QRX_PRIVATE_NAMESPACES=diary
 
# Port the system is running form, and default port for FOG_URL
QRX_PORT=3000