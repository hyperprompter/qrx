{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "llm-os",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "index.html",
        "height": "tall"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "New QRX Post",
        "forUserType": "moderator",
        "location": "subreddit",
        "endpoint": "/internal/menu/create-post"
      }
    ]
  },
  "permissions": {
    "reddit": true,
    "redis": true
  }
}